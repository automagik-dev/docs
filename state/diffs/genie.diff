+  await sql`
+    UPDATE tasks SET status = 'archived', archived_at = now(), updated_at = now()
+    WHERE project_id = ${project.id}
+      AND status NOT IN ('done', 'cancelled', 'archived')
+  `;
+
+  recordAuditEvent('project', project.id, 'archived', getActor(), { name }).catch(() => {});
