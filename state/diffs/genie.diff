+describe('snapshot file format', () => {
+  test('gzipSync + gunzipSync round-trips SQL content', async () => {
+    const { gunzipSync } = await import('node:zlib');
+    const sql = '-- PostgreSQL dump\nCREATE TABLE test (id int);\n';
