+  },
+} as const;
+
+// ============================================================================
+// pgserve Status Card
+// ============================================================================
+
+function PgserveCard({ health }: { health: SystemHealth }) {
+  const pgOk = health.pg.status === 'ok';
+  const natsOk = health.nats.status === 'connected';
+
+  return (
+    <div style={styles.card}>
