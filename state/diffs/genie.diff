+            borderRadius: theme.radiusSm,
+            cursor: dirty ? 'pointer' : 'default',
+            transition: 'all 0.2s ease',
+          }}
+        >
+          {saving ? 'Saving...' : saved && !dirty ? 'Saved' : 'Save Changes'}
+        </button>
+      </div>
+    </div>
+  );
+}
