+/** Grouped assistant message with nested tool calls. */
+interface MessageGroup {
+  /** The primary assistant or user or system message. */
+  turn: TurnRow;
+  /** Tool calls that belong under this assistant message. */
+  toolCalls: TurnRow[];
+}
