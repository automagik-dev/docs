+  skills?: string[];
+  /** Maximum number of agentic turns (API round-trips) before stopping. */
+  maxTurns?: number;
+  /** Run this agent as a background task (non-blocking, fire-and-forget). */
+  background?: boolean;
+  /** Scope for auto-loading agent memory files: 'user', 'project', or 'local'. */
