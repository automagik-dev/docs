-  const prefixMatch = text.match(/^(\[(\w+):([^\]]+)\]\s*)+/);
-  if (prefixMatch) {
-    applyHeaderPairs(result, prefixMatch[0], /\[(\w+):([^\]]+)\]/g);
-    result.cleanText = text.slice(prefixMatch[0].length).trim();
-  }
