# Mintlify automatically ignores these files and directories:
# .git, .github, .claude, .agents, .idea, node_modules,
# README.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md

# Draft content
drafts/
*.draft.mdx

# Internal engineering docs — surfaced inside automagik-dev/genie via
# git submodule + symlink (genie/docs/_internal/...) but excluded from
# the public Mintlify build at automagik.dev. Engineers reading the
# genie repo see these as if they were native; operators on the public
# site don't.
**/_internal/
